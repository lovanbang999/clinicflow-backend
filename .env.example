# ── Database (MySQL) ───────────────────────────────────────────
DATABASE_URL="mysql://username:password@localhost:3306/smartclinic?connection_limit=15&pool_timeout=10&connect_timeout=10"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_random_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_random_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Application ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# URL của frontend
FRONTEND_URL=http://localhost:3000

# ── Email (development: Nodemailer SMTP) ─────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=youremail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM="Smart Clinic <youremail@gmail.com>"

# ── Email (production: Resend) ───────────────────────────────
# Used when NODE_ENV=production. RESEND_FROM must use a verified Resend domain.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM="Smart Clinic <noreply@your-domain.com>"

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=SmartClinic

# ── Google AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Cloudflare AI ───────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
