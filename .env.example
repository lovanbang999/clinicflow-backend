# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=smartclinic
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=smart_clinic_db

# ── Application ──────────────────────────────────────────────
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
PORT=8080
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_random_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_random_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────────
# URL của frontend (production)
FRONTEND_URL=https://your-frontend-domain.com

# ── Email (Gmail) ────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=youremail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=Smart Clinic <youremail@gmail.com>

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDIARY_FOLDER=smart_clinic

# ── Google AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Cloudflare AI ───────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
