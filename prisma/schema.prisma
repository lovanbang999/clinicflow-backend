// SmartClinic Database Schema v3.0 — Production Ready
// Updated: Guest patient support, Room management, Invoice VAT/e-invoice,
//          bookingCode, source tracking, notification retry, slot cache, and more.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  PATIENT
  DOCTOR
  RECEPTIONIST
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  // QUEUED: kept for backward compatibility, deprecated — use BookingQueue table instead
  QUEUED
}

// Booking source: where the booking originated
enum BookingSource {
  ONLINE        // Patient booked via website/app
  WALK_IN       // Patient walked in, receptionist created booking
  PHONE         // Receptionist created booking via phone call
  RECEPTIONIST  // Receptionist booked on behalf (scheduled)
}

// Priority level for triage
enum BookingPriority {
  NORMAL
  URGENT
  EMERGENCY
}

enum ScheduleSlotStatus {
  SCHEDULED
  BLOCKED
}

enum RoomType {
  CONSULTATION
  ULTRASOUND
  PROCEDURE
  LAB
  WAITING
}

enum LabOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  REFUNDED
}

enum EInvoiceStatus {
  PENDING
  ISSUED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  INSURANCE
  CARD
}

enum NotificationType {
  APPOINTMENT_REMINDER
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  LAB_RESULT_READY
  INVOICE_ISSUED
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
}

model Icd10Code {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@map("icd10_codes")
}

// ============================================
// AUTH & USER
// ============================================

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole @default(PATIENT)

  fullName    String
  phone       String?
  avatar      String?
  dateOfBirth DateTime? @db.Date
  gender      Gender?
  address     String?

  isActive   Boolean   @default(false)
  isVerified Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?

  // Bookings — doctor always has account; patient linked via PatientProfile
  bookingsAsDoctor  Booking[] @relation("DoctorBookings")
  bookedBookings    Booking[] @relation("BookedByUser")
  cancelledBookings Booking[] @relation("CancelledByUser")

  workingHours    DoctorWorkingHours[]
  scheduleSlots   DoctorScheduleSlot[] @relation("DoctorScheduleSlots")
  breakTimes      DoctorBreakTime[]
  offDays         DoctorOffDay[]       @relation("DoctorOffDays")
  approvedOffDays DoctorOffDay[]       @relation("ApprovedOffDays")

  statusChanges BookingStatusHistory[] @relation("ChangedByUser")

  verificationCodes VerificationCode[]
  refreshTokens     RefreshToken[]

  labResultsRecorded LabResult[]    @relation("RecordedByUser")
  paymentsConfirmed  Payment[]      @relation("ConfirmedByUser")

  notifications        Notification[]
  auditLogs            AuditLog[]     @relation("ActorLogs")
  systemConfigsUpdated SystemConfig[] @relation("UpdatedByUser")

  @@index([email])
  @@index([role])
  @@index([phone])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique // SHA256 hash of the actual token
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  deviceInfo String?
  ipAddress  String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model VerificationCode {
  id        String           @id @default(uuid())
  userId    String
  code      String           // Hashed OTP/token
  type      VerificationType
  expiresAt DateTime
  isUsed    Boolean          @default(false)
  attempts  Int              @default(0) // Brute-force protection

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, isUsed])
  @@index([code])
  @@map("verification_codes")
}

// ============================================
// DOCTOR
// ============================================

model DoctorProfile {
  id     String @id @default(uuid())
  userId String @unique

  specialties       String[] @default([])
  qualifications    String[] @default([])
  yearsOfExperience Int      @default(0)
  bio               String?
  consultationFee   Decimal? @db.Decimal(12, 2) // Override service price if needed

  rating      Decimal @default(0) @db.Decimal(3, 2)
  reviewCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services DoctorService[] // Services this doctor can provide

  @@index([userId])
  @@map("doctor_profiles")
}

model DoctorWorkingHours {
  id        String    @id @default(uuid())
  doctorId  String
  dayOfWeek DayOfWeek
  startTime String    // "08:00" HH:mm
  endTime   String    // "17:00"
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
  @@map("doctor_working_hours")
}

model DoctorBreakTime {
  id        String   @id @default(uuid())
  doctorId  String
  breakDate DateTime @db.Date
  startTime String
  endTime   String
  reason    String?

  createdAt DateTime @default(now())

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, breakDate])
  @@map("doctor_break_times")
}

model DoctorOffDay {
  id         String   @id @default(uuid())
  doctorId   String
  offDate    DateTime @db.Date
  reason     String?
  approvedBy String?

  createdAt DateTime @default(now())

  doctor   User  @relation("DoctorOffDays", fields: [doctorId], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovedOffDays", fields: [approvedBy], references: [id])

  @@unique([doctorId, offDate])
  @@index([doctorId])
  @@map("doctor_off_days")
}

// Generated slots from working hours (actual bookable slots per day)
model DoctorScheduleSlot {
  id          String             @id @default(uuid())
  doctorId    String
  roomId      String?            // Optional — links to Room for conflict detection
  date        DateTime           @db.Date
  startTime   String
  endTime     String
  maxPatients Int                @default(1)
  bookedCount Int                @default(0) // Cache: updated on booking create/cancel. Avoids COUNT() joins on hot paths.
  type        String?
  notes       String?
  status      ScheduleSlotStatus @default(SCHEDULED)
  isActive    Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor User  @relation("DoctorScheduleSlots", fields: [doctorId], references: [id], onDelete: Cascade)
  room   Room? @relation(fields: [roomId], references: [id])

  @@index([doctorId, date])
  @@index([roomId, date]) // Check room conflicts
  @@map("doctor_schedule_slots")
}

// ============================================
// ROOM
// ============================================

// Physical rooms in the clinic. Prevents double-booking same room at same time.
model Room {
  id       String   @id @default(uuid())
  name     String   @unique // "Phòng khám 101", "Phòng siêu âm 2"
  type     RoomType @default(CONSULTATION)
  floor    String?
  capacity Int      @default(1)
  isActive Boolean  @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduleSlots DoctorScheduleSlot[]

  @@index([isActive])
  @@map("rooms")
}

// ============================================
// PATIENT
// ============================================

// PatientProfile is decoupled from User to support walk-in / guest patients.
// userId is nullable: NULL means the patient has no system account (isGuest = true).
// When a guest later creates an account, set userId and isGuest = false —
// all historical bookings are preserved because they reference patientProfileId.
model PatientProfile {
  id     String  @id @default(uuid())
  userId String? @unique // NULL for walk-in / guest patients

  // Denormalized from User for guest patients (and kept in sync for registered users)
  fullName    String
  phone       String?
  email       String?   // Optional — used for guest notifications
  dateOfBirth DateTime? @db.Date
  gender      Gender?
  address     String?

  patientCode String  @unique // "BN-2026-0001" — internal identifier used by receptionist
  isGuest     Boolean @default(false) // true = walk-in without account

  // Identity (required for BHYT claims and VAT invoices)
  nationalId String? // CCCD / CMND

  // Vital stats
  bloodType String?  // "A+", "B-", "O+", "AB+", "unknown"
  heightCm  Decimal? @db.Decimal(5, 1)
  weightKg  Decimal? @db.Decimal(5, 1)

  // Health insurance
  insuranceNumber    String?
  insuranceProvider  String?
  insuranceType      String?   // "BHYT" | "BHXH" | "Commercial"
  insuranceExpiry    DateTime? @db.Date
  insuranceCardFront String?   // CDN URL — front of BHYT card
  insuranceCardBack  String?   // CDN URL — back of BHYT card

  // Emergency contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Medical history (TEXT for phase 1; migrate to JSONB with ICD-10 codes later)
  allergies         String?
  chronicConditions String?
  familyHistory     String?
  occupation        String?
  ethnicity         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([userId])
  @@index([patientCode])
  @@index([phone])
  @@index([nationalId])
  @@map("patient_profiles")
}

// ============================================
// SCHEDULING
// ============================================

model Service {
  id              String    @id @default(uuid())
  name            String    @unique
  description     String?
  iconUrl         String?
  durationMinutes Int
  price           Decimal   @db.Decimal(12, 2)
  maxSlotsPerHour Int       @default(2)
  category        String?   // "Nội khoa", "Ngoại khoa", "Xét nghiệm"
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       Booking[]
  invoiceItems   InvoiceItem[]
  doctorServices DoctorService[]

  @@index([isActive])
  @@index([category])
  @@map("services")
}

// Join table: Doctor ↔ Service (many-to-many)
model DoctorService {
  id              String @id @default(uuid())
  doctorProfileId String
  serviceId       String

  createdAt DateTime @default(now())

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, serviceId])
  @@index([doctorProfileId])
  @@index([serviceId])
  @@map("doctor_services")
}

model Booking {
  id String @id @default(uuid())

  // Patient is always referenced via PatientProfile (works for both guests and registered users)
  patientProfileId String
  doctorId         String
  serviceId        String

  bookingCode String   @unique // "BK-20260317-0041" — human-readable reference
  bookingDate DateTime @db.Date
  startTime   String   // "09:00"
  endTime     String   // "09:30"

  status   BookingStatus   @default(PENDING)
  source   BookingSource   @default(ONLINE)
  priority BookingPriority @default(NORMAL)

  bookedBy     String? // userId of receptionist if booked on behalf
  patientNotes String?
  doctorNotes  String?

  cancelReason String?
  cancelledBy  String? // userId who cancelled

  // Timestamps for key state transitions
  confirmedAt    DateTime?
  checkedInAt    DateTime?
  reminderSentAt DateTime? // Tracks if reminder email/SMS was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile  PatientProfile         @relation(fields: [patientProfileId], references: [id])
  doctor          User                   @relation("DoctorBookings", fields: [doctorId], references: [id])
  service         Service                @relation(fields: [serviceId], references: [id])
  bookedByUser    User?                  @relation("BookedByUser", fields: [bookedBy], references: [id])
  cancelledByUser User?                  @relation("CancelledByUser", fields: [cancelledBy], references: [id])
  statusHistory   BookingStatusHistory[]
  queueRecord     BookingQueue?
  medicalRecord   MedicalRecord?
  invoice         Invoice?
  labOrders       LabOrder[]

  @@index([patientProfileId])
  @@index([doctorId])
  @@index([bookingDate])
  @@index([status])
  @@index([bookingCode])
  @@index([doctorId, bookingDate, startTime])
  @@index([doctorId, bookingDate, status])
  @@map("bookings")
}

// State machine:
// PENDING → CONFIRMED → CHECKED_IN → IN_PROGRESS → COMPLETED
//         ↘ CANCELLED  ↘ CANCELLED  ↘ NO_SHOW
model BookingQueue {
  id        String @id @default(uuid())
  bookingId String @unique

  // Denormalized for fast queue queries
  doctorId  String
  queueDate DateTime @db.Date

  queuePosition        Int
  estimatedWaitMinutes Int @default(0)

  calledAt    DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([doctorId, queueDate])
  @@index([doctorId, queueDate, queuePosition])
  @@map("booking_queue")
}

model BookingStatusHistory {
  id          String         @id @default(uuid())
  bookingId   String
  oldStatus   BookingStatus?
  newStatus   BookingStatus
  changedById String
  reason      String?
  metadata    Json?          // IP, device, extra context

  createdAt DateTime @default(now())
  // No updatedAt — append-only

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("ChangedByUser", fields: [changedById], references: [id])

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_history")
}

// ============================================
// EMR — ELECTRONIC MEDICAL RECORDS
// ============================================

model MedicalRecord {
  id        String @id @default(uuid())
  bookingId String @unique

  // Denormalized for fast patient history queries
  patientProfileId String
  doctorId         String

  chiefComplaint   String?
  clinicalFindings String?
  diagnosisCode    String? // ICD-10 e.g. "M54.5"
  diagnosisName    String? // "Đau thắt lưng cơ học"
  treatmentPlan    String?
  doctorNotes      String?

  followUpDate DateTime? @db.Date
  followUpNote String?

  isFinalized Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking      Booking       @relation(fields: [bookingId], references: [id])
  prescription Prescription?
  labOrders    LabOrder[]

  @@index([patientProfileId, createdAt(sort: Desc)])
  @@index([doctorId])
  @@index([bookingId])
  @@map("medical_records")
}

model Prescription {
  id              String @id @default(uuid())
  medicalRecordId String @unique

  // Denormalized
  patientProfileId String
  doctorId         String

  notes     String?
  isPrinted Boolean   @default(false)
  printedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  medicalRecord MedicalRecord      @relation(fields: [medicalRecordId], references: [id])
  items         PrescriptionItem[]

  @@index([patientProfileId])
  @@index([medicalRecordId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String @id @default(uuid())
  prescriptionId String

  medicineName String  // "Ibuprofen"
  dosage       String  // "400mg"
  frequency    String  // "3 lần/ngày"
  durationDays Int?
  quantity     Int
  unit         String  @default("viên")
  instructions String?
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

model LabOrder {
  id              String @id @default(uuid())
  bookingId       String
  medicalRecordId String

  // Denormalized
  patientProfileId String
  doctorId         String

  testName        String
  testDescription String?
  status          LabOrderStatus @default(PENDING)
  orderedAt       DateTime       @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking       Booking       @relation(fields: [bookingId], references: [id])
  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  result        LabResult?

  @@index([patientProfileId])
  @@index([medicalRecordId])
  @@index([status])
  @@map("lab_orders")
}

model LabResult {
  id         String @id @default(uuid())
  labOrderId String @unique

  resultText    String?
  resultFileUrl String?
  isAbnormal    Boolean?
  abnormalNote  String?
  recordedBy    String
  resultDate    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  labOrder       LabOrder @relation(fields: [labOrderId], references: [id])
  recordedByUser User     @relation("RecordedByUser", fields: [recordedBy], references: [id])

  @@index([labOrderId])
  @@map("lab_results")
}

// ============================================
// BILLING
// ============================================

model Invoice {
  id        String @id @default(uuid())
  bookingId String @unique

  // Denormalized
  patientProfileId String

  invoiceNumber  String        @unique // "INV-20260311-0001"
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)

  // VAT — required by Vietnamese law (Decree 123/2020)
  vatRate   Decimal @default(0) @db.Decimal(5, 2)  // 0.00 or 10.00
  vatAmount Decimal @default(0) @db.Decimal(12, 2)
  taxAmount Decimal @default(0) @db.Decimal(12, 2) // Legacy alias, keep for compatibility

  totalAmount Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(DRAFT)
  notes       String?

  // Insurance co-payment breakdown
  insuranceClaimed Boolean @default(false)
  insuranceAmount  Decimal @default(0) @db.Decimal(12, 2) // Covered by BHYT
  patientCoPayment Decimal @default(0) @db.Decimal(12, 2) // Patient's share

  // E-invoice (bắt buộc theo Thông tư 78/2021)
  einvoiceCode     String?
  einvoiceStatus   EInvoiceStatus @default(PENDING)
  einvoiceUrl      String?
  einvoiceIssuedAt DateTime?

  issuedAt DateTime?
  paidAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking  Booking       @relation(fields: [bookingId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([patientProfileId])
  @@index([status])
  @@index([paidAt])
  @@index([einvoiceStatus])
  @@map("invoices")
}

model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String

  serviceId String?

  // Price snapshot at invoice creation time — immune to future service price changes
  itemName   String
  unitPrice  Decimal @db.Decimal(12, 2)
  quantity   Int     @default(1)
  totalPrice Decimal @db.Decimal(12, 2)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String @id @default(uuid())
  invoiceId String

  amountPaid       Decimal       @db.Decimal(12, 2)
  insuranceCovered Decimal       @default(0) @db.Decimal(12, 2)
  patientPaid      Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  insuranceNumber  String?
  transactionRef   String?
  confirmedBy      String
  notes            String?
  paidAt           DateTime      @default(now())

  createdAt DateTime @default(now())
  // No updatedAt — append-only

  invoice         Invoice @relation(fields: [invoiceId], references: [id])
  confirmedByUser User    @relation("ConfirmedByUser", fields: [confirmedBy], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id     String  @id @default(uuid())
  userId String? // NULL for guest patients — use guestEmail / guestPhone instead

  // Guest delivery targets (used when userId is null)
  guestEmail String?
  guestPhone String?

  title   String
  content String
  type    NotificationType
  channel NotificationChannel

  isRead   Boolean @default(false)
  metadata Json?   // { bookingId, bookingCode, doctorName, appointmentTime, ... }

  // Delivery tracking
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  readAt       DateTime?

  // Retry logic — worker checks retryCount < maxRetries before re-queuing
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  nextRetryAt DateTime?
  provider    String?   // "SENDGRID" | "SES" | "TWILIO"

  createdAt DateTime @default(now())
  // No updatedAt — append-only

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([nextRetryAt]) // Worker polls this index for retry queue
  @@map("notifications")
}

// ============================================
// SYSTEM
// ============================================

model AuditLog {
  id      String  @id @default(uuid())
  actorId String? // NULL for system-initiated actions

  action     String // "CREATE_BOOKING", "CANCEL_BOOKING", "UPDATE_USER_STATUS", ...
  entityType String // "booking", "user", "invoice", ...
  entityId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  // No updatedAt — append-only

  actor User? @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id          String  @id @default(uuid())
  key         String  @unique // "clinic.working_hours.start"
  value       String           // "08:00"
  dataType    String  @default("string") // "string" | "number" | "boolean" | "json"
  category    String  @default("GENERAL") // "GENERAL" | "EMAIL" | "PAYMENT" | "SCHEDULE" | "INVOICE"
  description String?
  isPublic    Boolean @default(false) // false = never exposed via public API
  isSecret    Boolean @default(false) // true = value is encrypted at rest
  updatedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  updatedByUser User? @relation("UpdatedByUser", fields: [updatedBy], references: [id])

  @@index([category])
  @@map("system_configs")
}
