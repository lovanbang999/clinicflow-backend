generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────────────────────────────────────
// LOOKUP / REFERENCE
// ─────────────────────────────────────────────────────────────────────────────

model Icd10Code {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@map("icd10_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String                 @id @default(uuid())
  email                String                 @unique
  password             String
  role                 UserRole               @default(PATIENT)
  fullName             String
  phone                String?
  avatar               String?
  dateOfBirth          DateTime?              @db.Date
  gender               Gender?
  address              String?
  isActive             Boolean                @default(false)
  isVerified           Boolean                @default(false)
  deletedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  aiChatSessions       AiChatSession[]
  auditLogs            AuditLog[]             @relation("ActorLogs")
  statusChanges        BookingStatusHistory[] @relation("ChangedByUser")
  bookedBookings       Booking[]              @relation("BookedByUser")
  cancelledBookings    Booking[]              @relation("CancelledByUser")
  bookingsAsDoctor     Booking[]              @relation("DoctorBookings")
  breakTimes           DoctorBreakTime[]
  approvedOffDays      DoctorOffDay[]         @relation("ApprovedOffDays")
  offDays              DoctorOffDay[]         @relation("DoctorOffDays")
  doctorProfile        DoctorProfile?
  scheduleSlots        DoctorScheduleSlot[]   @relation("DoctorScheduleSlots")
  visitServiceOrdersAsPerformer VisitServiceOrder[] @relation("PerformedBy")
  workingHours         DoctorWorkingHours[]
  labResultsRecorded   LabResult[]            @relation("RecordedByUser")
  notifications        Notification[]
  patientProfile       PatientProfile?
  paymentsConfirmed    Payment[]              @relation("ConfirmedByUser")
  refreshTokens        RefreshToken[]
  systemConfigsUpdated SystemConfig[]         @relation("UpdatedByUser")
  verificationCodes    VerificationCode[]

  @@index([email])
  @@index([role])
  @@index([phone])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique @db.VarChar(512)
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model VerificationCode {
  id        String           @id @default(uuid())
  userId    String
  code      String
  type      VerificationType
  expiresAt DateTime
  isUsed    Boolean          @default(false)
  attempts  Int              @default(0)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, isUsed])
  @@index([code])
  @@map("verification_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// DOCTOR
// ─────────────────────────────────────────────────────────────────────────────

model DoctorProfile {
  id                String          @id @default(uuid())
  userId            String          @unique
  specialties       Json
  qualifications    Json
  yearsOfExperience Int             @default(0)
  bio               String?
  // Nếu consultationFee > 0 → B1 tạo Invoice CONSULTATION và thu tiền trước khi vào gặp BS
  // Nếu null hoặc 0 → không thu phí khám tư vấn
  consultationFee   Decimal?        @db.Decimal(12, 2)
  rating            Decimal         @default(0.00) @db.Decimal(3, 2)
  reviewCount       Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services          DoctorService[]

  @@index([userId])
  @@map("doctor_profiles")
}

model DoctorWorkingHours {
  id        String    @id @default(uuid())
  doctorId  String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  doctor    User      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
  @@map("doctor_working_hours")
}

model DoctorBreakTime {
  id        String   @id @default(uuid())
  doctorId  String
  breakDate DateTime @db.Date
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, breakDate])
  @@map("doctor_break_times")
}

model DoctorOffDay {
  id         String   @id @default(uuid())
  doctorId   String
  offDate    DateTime @db.Date
  reason     String?
  approvedBy String?
  createdAt  DateTime @default(now())
  approver   User?    @relation("ApprovedOffDays", fields: [approvedBy], references: [id])
  doctor     User     @relation("DoctorOffDays", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, offDate])
  @@index([doctorId])
  @@index([approvedBy], map: "doctor_off_days_approvedBy_fkey")
  @@map("doctor_off_days")
}

model DoctorScheduleSlot {
  id             String             @id @default(uuid())
  doctorId       String
  roomId         String?
  date           DateTime           @db.Date
  startTime      String
  endTime        String
  maxPatients    Int                @default(1)
  bookedCount    Int                @default(0)
  type           String?
  notes          String?
  status         ScheduleSlotStatus @default(SCHEDULED)
  isActive       Boolean            @default(true)
  maxPreBookings Int                @default(1)
  maxQueueSize   Int                @default(10)
  preBookedCount Int                @default(0)
  queueCount     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  doctor         User               @relation("DoctorScheduleSlots", fields: [doctorId], references: [id], onDelete: Cascade)
  room           Room?              @relation(fields: [roomId], references: [id])

  @@index([doctorId, date])
  @@index([roomId, date])
  @@map("doctor_schedule_slots")
}

model DoctorService {
  id              String        @id @default(uuid())
  doctorProfileId String
  serviceId       String
  createdAt       DateTime      @default(now())
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, serviceId])
  @@index([doctorProfileId])
  @@index([serviceId])
  @@map("doctor_services")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROOM
// ─────────────────────────────────────────────────────────────────────────────

model Room {
  id            String               @id @default(uuid())
  name          String               @unique
  type          RoomType             @default(CONSULTATION)
  floor         String?
  capacity      Int                  @default(1)
  isActive      Boolean              @default(true)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  bookings      Booking[]
  scheduleSlots DoctorScheduleSlot[]

  @@index([isActive])
  @@map("rooms")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT
// ─────────────────────────────────────────────────────────────────────────────

model PatientProfile {
  id                       String    @id @default(uuid())
  userId                   String?   @unique
  fullName                 String
  phone                    String?
  email                    String?
  dateOfBirth              DateTime? @db.Date
  gender                   Gender?
  address                  String?
  patientCode              String    @unique
  isGuest                  Boolean   @default(false)
  nationalId               String?
  bloodType                String?
  heightCm                 Decimal?  @db.Decimal(5, 1)
  weightKg                 Decimal?  @db.Decimal(5, 1)
  insuranceNumber          String?
  insuranceProvider        String?
  insuranceType            String?
  insuranceExpiry          DateTime? @db.Date
  insuranceCardFront       String?
  insuranceCardBack        String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  allergies                String?
  chronicConditions        String?
  familyHistory            String?
  occupation               String?
  ethnicity                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  bookings                 Booking[]
  user                     User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([patientCode])
  @@index([phone])
  @@index([nationalId])
  @@map("patient_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE & CATEGORY
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String              @id @default(uuid())
  code        String              @unique
  name        String
  description String?
  type        ServiceCategoryType @default(LAB)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  services    Service[]

  @@index([isActive])
  @@index([code])
  @@map("categories")
}

model Service {
  id              String        @id @default(uuid())
  name            String        @unique
  description     String?
  iconUrl         String?
  serviceCode     String?       @unique
  durationMinutes Int
  price           Decimal       @db.Decimal(12, 2)
  maxSlotsPerHour Int           @default(2)
  categoryId      String?
  preparationNotes String?
  tags            Json          @default("[]")

  // ── Routing logic ──────────────────────────────────────────────────────────
  // TECHNICIAN → tạo LabOrder → worklist KTV (/technician/lab-worklist)
  // DOCTOR     → tạo VisitServiceOrder → queue BS chuyên khoa (/doctor/examination)
  performerType   PerformerType @default(TECHNICIAN)

  // Xác định form kết quả đặc thù khi BS chuyên khoa nhập kết quả (chỉ áp dụng khi performerType = DOCTOR)
  examFormType    ExamFormType  @default(GENERAL)

  // Xác định form nhập kết quả cho KTV (chỉ áp dụng khi performerType = TECHNICIAN)
  labFormType     LabFormType   @default(GENERAL)

  isActive        Boolean       @default(true)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings           Booking[]
  doctorServices     DoctorService[]
  invoiceItems       InvoiceItem[]
  labOrders          LabOrder[]
  category           Category?           @relation(fields: [categoryId], references: [id])
  visitServiceOrders VisitServiceOrder[]

  @@index([isActive])
  @@index([categoryId])
  @@index([serviceCode])
  @@index([performerType])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKING & QUEUE
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id               String          @id @default(uuid())
  patientProfileId String
  doctorId         String
  // serviceId = null khi mới tạo (B1). BS tư vấn cập nhật sau khi xác định dịch vụ chính (B2)
  serviceId        String?
  bookingCode      String          @unique
  bookingDate      DateTime        @db.Date
  startTime        String?
  endTime          String?
  isPreBooked      Boolean         @default(true)
  estimatedTime    DateTime?
  status           BookingStatus   @default(PENDING)
  source           BookingSource   @default(ONLINE)
  priority         BookingPriority @default(NORMAL)
  bookedBy         String?
  patientNotes     String?
  doctorNotes      String?
  cancelReason     String?
  cancelledBy      String?
  confirmedAt      DateTime?
  checkedInAt      DateTime?
  reminderSentAt   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  roomId           String?

  aiChatSessions AiChatSession[]
  queueRecord    BookingQueue?
  statusHistory  BookingStatusHistory[]
  bookedByUser   User?          @relation("BookedByUser", fields: [bookedBy], references: [id])
  cancelledByUser User?         @relation("CancelledByUser", fields: [cancelledBy], references: [id])
  doctor         User           @relation("DoctorBookings", fields: [doctorId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])
  room           Room?          @relation(fields: [roomId], references: [id])
  service        Service?       @relation(fields: [serviceId], references: [id])
  invoices       Invoice[]
  labOrders      LabOrder[]
  medicalRecord  MedicalRecord?

  @@index([patientProfileId])
  @@index([doctorId])
  @@index([bookingDate])
  @@index([status])
  @@index([bookingCode])
  @@index([isPreBooked])
  @@index([doctorId, bookingDate, isPreBooked])
  @@index([doctorId, bookingDate, startTime])
  @@index([doctorId, bookingDate, status])
  @@index([bookedBy],     map: "bookings_bookedBy_fkey")
  @@index([cancelledBy],  map: "bookings_cancelledBy_fkey")
  @@index([roomId],       map: "bookings_roomId_fkey")
  @@index([serviceId],    map: "bookings_serviceId_fkey")
  @@map("bookings")
}

model BookingQueue {
  id                   String    @id @default(uuid())
  bookingId            String    @unique
  doctorId             String
  queueDate            DateTime  @db.Date
  queuePosition        Int
  estimatedWaitMinutes Int       @default(0)
  isPreBooked          Boolean   @default(true)
  scheduledTime        String?
  calledAt             DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  booking              Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([doctorId, queueDate])
  @@index([doctorId, queueDate, queuePosition])
  @@index([doctorId, queueDate, isPreBooked, scheduledTime])
  @@map("booking_queue")
}

model BookingStatusHistory {
  id          String         @id @default(uuid())
  bookingId   String
  oldStatus   BookingStatus?
  newStatus   BookingStatus
  changedById String?
  reason      String?
  metadata    Json?
  createdAt   DateTime       @default(now())
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy   User?          @relation("ChangedByUser", fields: [changedById], references: [id])

  @@index([bookingId])
  @@index([createdAt])
  @@index([changedById], map: "booking_status_history_changedById_fkey")
  @@map("booking_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDICAL RECORD & CLINICAL
// ─────────────────────────────────────────────────────────────────────────────

model MedicalRecord {
  id               String    @id @default(uuid())
  bookingId        String    @unique
  patientProfileId String
  doctorId         String

  visitStep        VisitStep @default(SYMPTOMS_TAKEN)
  version          Int       @default(0)

  // Sinh hiệu (B2 — BS tư vấn ghi)
  bloodPressure    String?
  heartRate        Int?
  temperature      Decimal?  @db.Decimal(4, 1)
  spO2             Int?
  weightKg         Decimal?  @db.Decimal(5, 2)
  heightCm         Decimal?  @db.Decimal(5, 1)
  bmi              Decimal?  @db.Decimal(4, 1)

  // Triệu chứng & lịch sử (B2)
  chiefComplaint     String?
  additionalSymptoms String?
  clinicalFindings   String?
  doctorNotes        String?
  medicalHistory     String?
  allergies          String?
  symptomsAt         DateTime?

  // Chẩn đoán & điều trị (B7)
  diagnosisCode  String?
  diagnosisName  String?
  treatmentPlan  String?
  followUpDate   DateTime? @db.Date
  followUpNote   String?

  // Timestamps
  orderedAt    DateTime?
  diagnosedAt  DateTime?
  prescribedAt DateTime?
  isFinalized  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  labOrders          LabOrder[]
  booking            Booking             @relation(fields: [bookingId], references: [id])
  prescription       Prescription?
  visitServiceOrders VisitServiceOrder[]

  @@index([patientProfileId, createdAt(sort: Desc)])
  @@index([doctorId])
  @@index([bookingId])
  @@index([visitStep])
  @@map("medical_records")
}

// Dịch vụ Nhóm 2 (performerType = DOCTOR): BS chuyên khoa thực hiện
// VD: Khám mắt, khám răng, khám tai mũi họng...
model VisitServiceOrder {
  id               String          @id @default(uuid())
  medicalRecordId  String
  serviceId        String
  patientProfileId String
  bookingId        String
  status           ServiceOrderStatus @default(PENDING)
  orderedBy        String          // userId của BS tư vấn ra chỉ định
  performedBy      String?         // userId của BS chuyên khoa thực hiện
  performer        User?           @relation("PerformedBy", fields: [performedBy], references: [id])

  // STT tại phòng chuyên khoa (tương tự LabOrder.queueNumber)
  // Được gán sau khi BN thanh toán (B3)
  queueNumber      Int?

  // Thời điểm BN thanh toán dịch vụ này (B3)
  paidAt           DateTime?

  // Kết quả khám chuyên khoa (B4')
  resultText       String?   @db.Text
  findings         Json?     // Structured specialist examination data
  resultFileUrl    String?
  isAbnormal       Boolean?
  abnormalNote     String?

  // Ghi chú / khuyến nghị BS chuyên khoa gửi lại BS tư vấn
  specialistNote   String?   @db.Text

  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Smart Queue Suggestion
  suggestedOrder   Int?      // Recommended order for the patient to visit
  groupKey         String?   // Key to group services together (e.g., by room)

  prescriptionItems PrescriptionItem[]
  medicalRecord     MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  service           Service       @relation(fields: [serviceId], references: [id])
  invoiceItem       InvoiceItem?

  @@index([medicalRecordId])
  @@index([patientProfileId])
  @@index([bookingId])
  @@index([status])
  @@index([serviceId], map: "visit_service_orders_serviceId_fkey")
  @@map("visit_service_orders")
}

// Dịch vụ Nhóm 1 (performerType = TECHNICIAN): KTV thực hiện
// VD: XN máu, siêu âm, X-quang, ECG...
model LabOrder {
  id               String         @id @default(uuid())
  bookingId        String
  medicalRecordId  String
  patientProfileId String
  doctorId         String         // BS tư vấn ra chỉ định
  testName         String
  testDescription  String?
  serviceId        String?
  status           LabOrderStatus @default(PENDING)

  // Được gán sau khi BN thanh toán (B3) — STT tại phòng lab/kỹ thuật
  queueNumber      Int?

  orderedAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Smart Queue Suggestion
  suggestedOrder   Int?      // Recommended order for the patient to visit
  groupKey         String?   // Key to group services together (e.g., by room)

  invoiceItem       InvoiceItem?
  booking           Booking            @relation(fields: [bookingId], references: [id])
  medicalRecord     MedicalRecord      @relation(fields: [medicalRecordId], references: [id])
  service           Service?           @relation(fields: [serviceId], references: [id])
  result            LabResult?
  prescriptionItems PrescriptionItem[]

  @@index([patientProfileId])
  @@index([medicalRecordId])
  @@index([bookingId],  map: "lab_orders_bookingId_fkey")
  @@index([serviceId],  map: "lab_orders_serviceId_fkey")
  @@index([doctorId])
  @@index([status])
  @@map("lab_orders")
}

model LabResult {
  id            String   @id @default(uuid())
  labOrderId    String   @unique
  resultText    String?  @db.Text
  resultFileUrl String?
  isAbnormal    Boolean?
  abnormalNote  String?
  recordedBy    String   // userId của KTV
  resultDate    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  labOrder      LabOrder @relation(fields: [labOrderId], references: [id])
  recordedByUser User    @relation("RecordedByUser", fields: [recordedBy], references: [id])

  @@index([labOrderId])
  @@index([recordedBy], map: "lab_results_recordedBy_fkey")
  @@map("lab_results")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRESCRIPTION
// ─────────────────────────────────────────────────────────────────────────────

model Prescription {
  id               String    @id @default(uuid())
  medicalRecordId  String    @unique
  patientProfileId String
  doctorId         String

  notes            String?
  isPrinted        Boolean   @default(false)
  printedAt        DateTime?

  // B8 — Thuốc tùy chọn:
  // null = chưa quyết định, true = mua tại phòng khám, false = mua ngoài
  isFulfilledInternally Boolean?
  // Thời điểm BN nhận thuốc tại quầy dược (khi isFulfilledInternally = true)
  fulfilledAt           DateTime?
  // FK đến Invoice PHARMACY (chỉ có khi isFulfilledInternally = true)
  pharmacyInvoiceId     String?   @unique
  pharmacyInvoice       Invoice?  @relation("PharmacyInvoice", fields: [pharmacyInvoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         PrescriptionItem[]
  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])

  @@index([patientProfileId])
  @@index([medicalRecordId])
  @@index([pharmacyInvoiceId], map: "prescriptions_pharmacyInvoiceId_fkey")
  @@map("prescriptions")
}

model PrescriptionItem {
  id                  String    @id @default(uuid())
  prescriptionId      String
  visitServiceOrderId String?
  labOrderId          String?
  medicineName        String
  dosage              String
  frequency           String
  durationDays        Int?
  quantity            Int
  unit                String    @default("viên")
  instructions        String?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())

  labOrder          LabOrder?          @relation(fields: [labOrderId],          references: [id])
  prescription      Prescription       @relation(fields: [prescriptionId],      references: [id], onDelete: Cascade)
  visitServiceOrder VisitServiceOrder? @relation(fields: [visitServiceOrderId], references: [id])

  @@index([prescriptionId])
  @@index([labOrderId],          map: "prescription_items_labOrderId_fkey")
  @@index([visitServiceOrderId], map: "prescription_items_visitServiceOrderId_fkey")
  @@map("prescription_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id               String         @id @default(uuid())
  bookingId        String
  patientProfileId String
  invoiceType      InvoiceType    @default(CONSULTATION)
  invoiceNumber    String         @unique
  subtotal         Decimal        @db.Decimal(12, 2)
  discountAmount   Decimal        @default(0.00) @db.Decimal(12, 2)
  vatRate          Decimal        @default(0.00) @db.Decimal(5, 2)
  vatAmount        Decimal        @default(0.00) @db.Decimal(12, 2)
  taxAmount        Decimal        @default(0.00) @db.Decimal(12, 2)
  totalAmount      Decimal        @db.Decimal(12, 2)
  status           InvoiceStatus  @default(DRAFT)
  notes            String?
  insuranceClaimed Boolean        @default(false)
  insuranceAmount  Decimal        @default(0.00) @db.Decimal(12, 2)
  patientCoPayment Decimal        @default(0.00) @db.Decimal(12, 2)
  einvoiceCode     String?
  einvoiceStatus   EInvoiceStatus @default(PENDING)
  einvoiceUrl      String?
  einvoiceIssuedAt DateTime?
  issuedAt         DateTime?
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  items        InvoiceItem[]
  booking      Booking       @relation(fields: [bookingId],        references: [id])
  payments     Payment[]
  // Relation ngược từ Prescription.pharmacyInvoice (chỉ Invoice type=PHARMACY mới có)
  prescription Prescription? @relation("PharmacyInvoice")

  @@index([bookingId])
  @@index([patientProfileId])
  @@index([invoiceType])
  @@index([status])
  @@index([paidAt])
  @@index([einvoiceStatus])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  serviceId   String?
  itemName    String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int      @default(1)
  totalPrice  Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  // Link đến LabOrder (Nhóm 1 — KTV thực hiện)
  labOrderId          String?            @unique
  labOrder            LabOrder?          @relation(fields: [labOrderId],          references: [id])

  // Link đến VisitServiceOrder (Nhóm 2 — BS chuyên khoa thực hiện)
  visitServiceOrderId String?            @unique
  visitServiceOrder   VisitServiceOrder? @relation(fields: [visitServiceOrderId], references: [id])

  invoice  Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service  Service?  @relation(fields: [serviceId], references: [id])

  @@index([invoiceId])
  @@index([serviceId])
  @@map("invoice_items")
}

model Payment {
  id               String        @id @default(uuid())
  invoiceId        String
  amountPaid       Decimal       @db.Decimal(12, 2)
  insuranceCovered Decimal       @default(0.00) @db.Decimal(12, 2)
  patientPaid      Decimal       @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  insuranceNumber  String?
  transactionRef   String?
  confirmedBy      String
  notes            String?
  paidAt           DateTime      @default(now())
  createdAt        DateTime      @default(now())
  confirmedByUser  User          @relation("ConfirmedByUser", fields: [confirmedBy], references: [id])
  invoice          Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
  @@index([confirmedBy], map: "payments_confirmedBy_fkey")
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION, AUDIT, SYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id           String              @id @default(uuid())
  userId       String?
  guestEmail   String?
  guestPhone   String?
  title        String
  content      String
  type         NotificationType
  channel      NotificationChannel
  isRead       Boolean             @default(false)
  metadata     Json?
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  readAt       DateTime?
  retryCount   Int                 @default(0)
  maxRetries   Int                 @default(3)
  nextRetryAt  DateTime?
  provider     String?
  createdAt    DateTime            @default(now())
  user         User?               @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([nextRetryAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  dataType      String   @default("string")
  category      String   @default("GENERAL")
  description   String?
  isPublic      Boolean  @default(false)
  isSecret      Boolean  @default(false)
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  updatedByUser User?    @relation("UpdatedByUser", fields: [updatedBy], references: [id])

  @@index([category])
  @@index([updatedBy], map: "system_configs_updatedBy_fkey")
  @@map("system_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CHAT
// ─────────────────────────────────────────────────────────────────────────────

model AiChatSession {
  id               String           @id @default(uuid())
  userId           String
  patientProfileId String?
  modelName        String           @default("gemini-2.5-flash")
  totalTokens      Int              @default(0)
  outcome          AiSessionOutcome @default(ONGOING)
  bookingId        String?
  feedbackRating   Int?
  feedbackNote     String?
  reportedAt       DateTime?
  startedAt        DateTime         @default(now())
  endedAt          DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  messages         AiChatMessage[]
  booking          Booking?         @relation(fields: [bookingId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
  @@index([outcome])
  @@index([startedAt])
  @@index([bookingId], map: "ai_chat_sessions_bookingId_fkey")
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id         String        @id @default(uuid())
  sessionId  String
  role       AiMessageRole
  content    String        @db.Text
  toolName   String?
  toolInput  Json?
  toolOutput Json?
  toolError  String?       @db.Text
  tokenCount Int?
  createdAt  DateTime      @default(now())
  session    AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([toolName])
  @@map("ai_chat_messages")
}

